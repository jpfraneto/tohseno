# Private product input: one line or a whole document, never committed.
MASTER_PROMPT.md

# Local tooling and operating-system noise.
.DS_Store
node_modules/

# Machine-local configuration written by `bun run setup`.
# Contains your identifiers and key *paths* — personal, not for the repo.
Config/Local.xcconfig
Config/DevelopmentEndpoint.xcconfig
app.config.json

# Shot-owned runtime. Persistent development SQLite data is deliberately
# separate from process state and logs; none may enter Git.
.tohseno/data/
.tohseno/run/

# Private creation input and generated local previews travel with a copied shot
# directory, but never enter its Git history.
.tohseno/provenance/
.tohseno/artifacts/

# Credentials must never enter git.
.env
.env.*
!.env.example
*.p8
*.p12
*.pem
*.pfx
*.mobileprovision

# Xcode noise.
xcuserdata/
DerivedData/
build/

# fastlane output.
fastlane/report.xml
fastlane/test_output/
fastlane/builds/
