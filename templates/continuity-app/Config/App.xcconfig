// The build configuration the Xcode project reads.
//
// These are shippable defaults: the app builds and runs in the simulator
// exactly as cloned, with zero keys. `bun run setup` writes Config/Local.xcconfig
// (gitignored) with your own identifiers; it overrides everything here.
// The only manual step for a device build is selecting your signing team,
// either via setup or in Xcode's Signing & Capabilities tab.

APP_DISPLAY_NAME = Writing
APP_BUNDLE_ID = com.tohseno.base-writing
DEVELOPMENT_TEAM =

// Key slots for flag-gated modules. Public identifiers only — never secrets.
REVENUECAT_PUBLIC_KEY =

// Prototype-only provider secret. Put its value only in gitignored
// Local.xcconfig and only while running on an owner-controlled device.
// DEV_SECRET_FOR_BUILD is deliberately blank for simulators and every Release
// build, so TestFlight and App Store archives cannot inherit the local value.
DEV_SECRET =

#include? "Local.xcconfig"

// Even the raw local setting is cleared outside an owner-device Debug build,
// keeping it out of simulator and archive build settings as well as Info.plist.
DEV_SECRET[config=Release] =
DEV_SECRET[sdk=iphonesimulator*] =
DEV_SECRET_FOR_BUILD =
DEV_SECRET_FOR_BUILD[config=Debug][sdk=iphoneos*] = $(DEV_SECRET)
