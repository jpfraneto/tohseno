{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tohseno.com/schemas/contracts/signed-request-envelope-v1",
  "title": "SignedRequestEnvelopeV1",
  "description": "A versioned request authorization envelope binding the signature to the actual HTTP method, origin-form path, exact body digest, timestamp, nonce, and signer.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "protocolVersion",
    "method",
    "path",
    "bodyHash",
    "timestamp",
    "nonce",
    "signer",
    "signature"
  ],
  "properties": {
    "protocolVersion": { "const": "1" },
    "method": {
      "type": "string",
      "pattern": "^[A-Z]+$",
      "minLength": 3,
      "maxLength": 16
    },
    "path": {
      "description": "Actual origin-form request path without query string or fragment.",
      "type": "string",
      "pattern": "^/(?:[A-Za-z0-9._~!$&'()*+,;=:@%/-]*)$",
      "maxLength": 2048
    },
    "bodyHash": { "$ref": "#/$defs/digest" },
    "timestamp": { "$ref": "#/$defs/timestamp" },
    "nonce": {
      "type": "string",
      "minLength": 16,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9_-]+$"
    },
    "signer": { "$ref": "#/$defs/signer" },
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "required": ["encoding", "value"],
      "properties": {
        "encoding": { "const": "base64url" },
        "value": {
          "type": "string",
          "minLength": 16,
          "maxLength": 2048,
          "pattern": "^[A-Za-z0-9_-]+$"
        }
      }
    }
  },
  "$defs": {
    "token": {
      "type": "string",
      "minLength": 2,
      "maxLength": 120,
      "pattern": "^[A-Za-z0-9._+-]+$"
    },
    "canonicalLine": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4096,
      "pattern": "^[^\\r\\n]+$"
    },
    "digest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "value"],
      "properties": {
        "algorithm": { "const": "sha-256" },
        "value": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "signer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["suite", "keyId", "publicKey"],
      "properties": {
        "suite": { "$ref": "#/$defs/token" },
        "keyId": { "$ref": "#/$defs/canonicalLine" },
        "publicKey": { "$ref": "#/$defs/canonicalLine" }
      }
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    }
  }
}
