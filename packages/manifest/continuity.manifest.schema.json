{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tohseno.com/schemas/continuity.manifest/0.3.0",
  "title": "TOHSENO Continuity Manifest",
  "description": "The machine-readable record of what a continuity app does. The bounded field space is a reliability mechanism: a feature that cannot be expressed as a valid manifest field is unsupported, and the agent says so instead of improvising. Runtime-enforced behavior, coding-agent guidance, and operator/deployment metadata are separated so prose cannot silently change runtime guarantees.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "application",
    "runtime",
    "guidance",
    "operations"
  ],
  "properties": {
    "schemaVersion": {
      "const": "0.3.0"
    },
    "application": {
      "$ref": "#/$defs/application"
    },
    "runtime": {
      "$ref": "#/$defs/runtime"
    },
    "guidance": {
      "$ref": "#/$defs/guidance"
    },
    "operations": {
      "$ref": "#/$defs/operations"
    }
  },
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1000,
      "pattern": "\\S"
    },
    "contractId": {
      "type": "string",
      "minLength": 3,
      "maxLength": 120,
      "pattern": "^[a-z0-9][a-z0-9._-]*$"
    },
    "nonEmptyStringArray": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/nonEmptyString"
      }
    },
    "application": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "coreAction"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 3,
          "maxLength": 120,
          "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)+$"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80,
          "pattern": "\\S"
        },
        "coreAction": {
          "description": "One sentence naming the one observable action the app is built around.",
          "type": "string",
          "minLength": 12,
          "maxLength": 240,
          "pattern": "^[^\\r\\n]+$"
        }
      }
    },
    "completionCondition": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "thresholdMs"],
          "properties": {
            "kind": { "const": "active-duration" },
            "thresholdMs": {
              "type": "integer",
              "minimum": 1,
              "maximum": 86400000
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "threshold", "unit"],
          "properties": {
            "kind": { "const": "count" },
            "threshold": {
              "type": "integer",
              "minimum": 1,
              "maximum": 1000000
            },
            "unit": { "$ref": "#/$defs/contractId" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "predicate"],
          "properties": {
            "kind": { "const": "explicit" },
            "predicate": { "$ref": "#/$defs/nonEmptyString" }
          }
        }
      ]
    },
    "interruptionCondition": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "afterMs"],
          "properties": {
            "kind": { "const": "inactivity" },
            "afterMs": {
              "type": "integer",
              "minimum": 1,
              "maximum": 86400000
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind"],
          "properties": {
            "kind": { "const": "lifecycle-exit" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "predicate"],
          "properties": {
            "kind": { "const": "explicit" },
            "predicate": { "$ref": "#/$defs/nonEmptyString" }
          }
        }
      ]
    },
    "action": {
      "type": "object",
      "additionalProperties": false,
      "required": ["input", "completion", "interruption", "checkpoint"],
      "properties": {
        "input": {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "mediaTypes"],
          "properties": {
            "kind": { "$ref": "#/$defs/contractId" },
            "mediaTypes": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "type": "string",
                "pattern": "^[a-z0-9.+-]+/[a-z0-9.+-]+$"
              }
            },
            "constraints": {
              "$ref": "#/$defs/nonEmptyStringArray"
            }
          }
        },
        "completion": {
          "$ref": "#/$defs/completionCondition"
        },
        "interruption": {
          "type": "object",
          "additionalProperties": false,
          "required": ["condition", "partialAction", "resumption"],
          "properties": {
            "condition": {
              "$ref": "#/$defs/interruptionCondition"
            },
            "partialAction": {
              "enum": ["preserve", "discard-with-explicit-consent"]
            },
            "resumption": {
              "enum": ["resume", "start-new"]
            }
          }
        },
        "checkpoint": {
          "oneOf": [
            { "const": "on-progress" },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["intervalMs"],
              "properties": {
                "intervalMs": {
                  "type": "integer",
                  "minimum": 100,
                  "maximum": 3600000
                }
              }
            }
          ]
        }
      }
    },
    "runtimeProperties": {
      "description": "Reliability invariants every generated app must enforce and test.",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "offlineCoreAction",
        "noAccountBeforeValue",
        "localFirstRecord",
        "crashSafePersistence",
        "stableEventIdentity"
      ],
      "properties": {
        "offlineCoreAction": {
          "description": "How much of the core action works with no network. full: the entire core action works offline. degraded-readonly: existing records stay readable offline but the core action needs network. network-required: the core action needs network by nature (live AI, realtime multiplayer). Anything but full requires offlineSurface and a non-empty externalDisclosure inventory.",
          "enum": ["full", "degraded-readonly", "network-required"]
        },
        "offlineSurface": {
          "description": "What a person can still do with no network. Required unless offlineCoreAction is full; omitted when it is.",
          "$ref": "#/$defs/nonEmptyString"
        },
        "noAccountBeforeValue": {
          "description": "The core action is reachable from a fresh install without any account, login, or email capture. Identity is a silently generated seed phrase.",
          "const": true
        },
        "localFirstRecord": { "const": true },
        "crashSafePersistence": {
          "description": "Committed data survives process death; writes are atomic.",
          "const": true
        },
        "stableEventIdentity": { "const": true }
      },
      "allOf": [
        {
          "if": {
            "properties": { "offlineCoreAction": { "const": "full" } },
            "required": ["offlineCoreAction"]
          },
          "then": { "not": { "required": ["offlineSurface"] } },
          "else": { "required": ["offlineSurface"] }
        }
      ]
    },
    "feedback": {
      "type": "object",
      "additionalProperties": false,
      "required": ["onCompletion", "onInterruption"],
      "properties": {
        "onProgress": { "$ref": "#/$defs/nonEmptyString" },
        "onCompletion": { "$ref": "#/$defs/nonEmptyString" },
        "onInterruption": { "$ref": "#/$defs/nonEmptyString" }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "mediaType", "codec", "export"],
      "properties": {
        "id": { "$ref": "#/$defs/contractId" },
        "mediaType": {
          "type": "string",
          "pattern": "^[a-z0-9.+-]+/[a-z0-9.+-]+$"
        },
        "codec": { "$ref": "#/$defs/contractId" },
        "export": {
          "enum": ["owner-selected", "private-by-default", "none"]
        }
      }
    },
    "reflection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "trigger",
        "eventEligibility",
        "consent",
        "inputDisclosure",
        "policyId",
        "fallback"
      ],
      "properties": {
        "mode": {
          "enum": ["local-deterministic", "local-ai", "remote-service"]
        },
        "trigger": {
          "enum": ["after-event-opt-in", "after-event-automatic"]
        },
        "eventEligibility": {
          "enum": ["completed-only", "completed-or-interrupted"]
        },
        "consent": {
          "enum": ["per-event", "standing-explicit"]
        },
        "inputDisclosure": {
          "enum": ["none", "derived-features", "private-artifact"]
        },
        "policyId": { "$ref": "#/$defs/contractId" },
        "fallback": { "const": "continue-without-reflection" }
      }
    },
    "privacy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "localStorage",
        "publicByDefault",
        "externalDisclosure",
        "telemetry"
      ],
      "properties": {
        "localStorage": {
          "enum": ["platform-private", "application-encrypted"]
        },
        "publicByDefault": {
          "description": "Whether records are public by default. Private is the default the skeleton ships with; the builder decides otherwise explicitly.",
          "type": "boolean"
        },
        "externalDisclosure": {
          "description": "Every way data leaves the device, declared. Empty means nothing leaves.",
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/nonEmptyString" }
        },
        "telemetry": {
          "enum": [
            "none",
            "operational-metadata-only",
            "minimal-pseudonymous"
          ]
        }
      }
    },
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "creation", "crossAppLinking"],
      "properties": {
        "mode": { "enum": ["none", "seed-phrase", "local-contextual"] },
        "creation": {
          "enum": ["first-action", "first-committed-event", "first-launch"]
        },
        "wordlist": { "const": "bip39-english" },
        "suite": { "$ref": "#/$defs/contractId" },
        "crossAppLinking": {
          "enum": ["never", "explicit-consent-only"]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "mode": { "const": "seed-phrase" } },
            "required": ["mode"]
          },
          "then": {
            "required": ["wordlist"],
            "not": { "required": ["suite"] }
          }
        },
        {
          "if": {
            "properties": { "mode": { "const": "local-contextual" } },
            "required": ["mode"]
          },
          "then": {
            "required": ["suite"],
            "not": { "required": ["wordlist"] }
          }
        },
        {
          "if": {
            "properties": { "mode": { "const": "none" } },
            "required": ["mode"]
          },
          "then": {
            "allOf": [
              { "not": { "required": ["suite"] } },
              { "not": { "required": ["wordlist"] } }
            ]
          }
        }
      ]
    },
    "recovery": {
      "type": "object",
      "additionalProperties": false,
      "required": ["offer", "identity", "content"],
      "properties": {
        "offer": {
          "enum": ["after-first-value", "settings-only", "never"]
        },
        "identity": {
          "enum": ["none", "manual", "automatic-encrypted-backup", "opt-in-encrypted-backup"]
        },
        "content": {
          "enum": ["none", "manual-export", "opt-in-encrypted-backup"]
        }
      }
    },
    "synchronization": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "conflictPolicy"],
      "properties": {
        "mode": { "const": "opt-in-encrypted" },
        "conflictPolicy": { "$ref": "#/$defs/nonEmptyString" }
      }
    },
    "modules": {
      "description": "The flag-gated modules of the indie stack. Present in every generated app's code; a module is integrated by flipping its flag in AppConfig, never by rearchitecting.",
      "type": "object",
      "additionalProperties": false,
      "required": ["paywall", "shareCard", "notifications", "sessionLink", "tokenMint"],
      "properties": {
        "paywall": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled", "provider"],
          "properties": {
            "enabled": { "type": "boolean" },
            "provider": { "const": "revenuecat" },
            "publicKeySlot": {
              "description": "The AppConfig slot name that holds the provider's public key. Never the key itself.",
              "$ref": "#/$defs/contractId"
            }
          }
        },
        "shareCard": {
          "description": "A locally rendered share image handed to the system share sheet. No network.",
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled"],
          "properties": {
            "enabled": { "type": "boolean" }
          }
        },
        "notifications": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled"],
          "properties": {
            "enabled": { "type": "boolean" }
          }
        },
        "sessionLink": {
          "description": "RESERVED, not implemented: scan a QR on a web page, confirm in the app, and a signed session connects the browser to the app identity. The flag and field exist so the pattern has a name; enabling it is unsupported in 0.3.0.",
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled", "status"],
          "properties": {
            "enabled": { "const": false },
            "status": { "const": "reserved" }
          }
        },
        "tokenMint": {
          "description": "RESERVED, not implemented: a minimal server that mints short-lived third-party credentials (e.g. ephemeral realtime-AI tokens) and never receives user content. The flag exists so the pattern has a name; enabling it is unsupported in 0.3.0 — prototypes declare a development secret in operations.developmentSecrets instead.",
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled", "status"],
          "properties": {
            "enabled": { "const": false },
            "status": { "const": "reserved" }
          }
        },
        "extensions": {
          "description": "App-specific modules beyond the named indie stack, declared instead of narrated in implementationNotes. Each key is the extension's contract id; each value is flag-gated, key-slotted, and honest about the network. An enabled network-touching extension must be reflected in the external disclosure inventory.",
          "type": "object",
          "minProperties": 1,
          "maxProperties": 16,
          "propertyNames": { "$ref": "#/$defs/contractId" },
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "required": ["enabled", "description"],
            "properties": {
              "enabled": { "type": "boolean" },
              "description": { "$ref": "#/$defs/nonEmptyString" },
              "keySlot": {
                "description": "The AppConfig slot name that holds the extension's public identifier. Never the key itself.",
                "$ref": "#/$defs/contractId"
              },
              "requiresNetwork": { "type": "boolean" }
            }
          }
        }
      }
    },
    "runtime": {
      "description": "Behavior and privacy properties a generated application must enforce and test.",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "properties",
        "action",
        "feedback",
        "continuity",
        "privacy",
        "identity",
        "recovery",
        "modules"
      ],
      "properties": {
        "properties": { "$ref": "#/$defs/runtimeProperties" },
        "action": { "$ref": "#/$defs/action" },
        "feedback": { "$ref": "#/$defs/feedback" },
        "continuity": {
          "type": "object",
          "additionalProperties": false,
          "required": ["accumulated", "artifacts"],
          "properties": {
            "accumulated": {
              "type": "object",
              "additionalProperties": false,
              "required": ["description", "projections"],
              "properties": {
                "description": { "$ref": "#/$defs/nonEmptyString" },
                "projections": {
                  "$ref": "#/$defs/nonEmptyStringArray"
                }
              }
            },
            "artifacts": {
              "type": "array",
              "minItems": 1,
              "maxItems": 8,
              "items": { "$ref": "#/$defs/artifact" }
            }
          }
        },
        "reflection": { "$ref": "#/$defs/reflection" },
        "privacy": { "$ref": "#/$defs/privacy" },
        "identity": { "$ref": "#/$defs/identity" },
        "recovery": { "$ref": "#/$defs/recovery" },
        "synchronization": { "$ref": "#/$defs/synchronization" },
        "modules": { "$ref": "#/$defs/modules" }
      },
      "allOf": [
        {
          "if": {
            "required": ["properties"],
            "properties": {
              "properties": {
                "required": ["offlineCoreAction"],
                "properties": {
                  "offlineCoreAction": {
                    "enum": ["degraded-readonly", "network-required"]
                  }
                }
              }
            }
          },
          "then": {
            "properties": {
              "privacy": {
                "properties": {
                  "externalDisclosure": { "minItems": 1 }
                }
              }
            }
          }
        }
      ]
    },
    "guidance": {
      "description": "Non-executable judgment constraints for a coding agent: look, tone, and notes. The builder decides the mechanics.",
      "type": "object",
      "additionalProperties": false,
      "required": ["visualDirection", "tonalDirection"],
      "properties": {
        "visualDirection": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "tonalDirection": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "implementationNotes": {
          "$ref": "#/$defs/nonEmptyStringArray"
        }
      }
    },
    "operations": {
      "description": "Operator and deployment metadata. It cannot weaken runtime guarantees.",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "deploymentTargets",
        "requiresServer",
        "ejectionRequired",
        "approvalRequiredFor"
      ],
      "properties": {
        "deploymentTargets": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": ["native-ios", "native-android", "web", "server"]
          }
        },
        "requiresServer": { "type": "boolean" },
        "serverRole": {
          "description": "Why the server exists. token-mint-only: mints short-lived third-party credentials and never receives user content. sync-relay: relays application-encrypted blobs it cannot read. app-backend: receives user data and must appear in the external disclosure inventory. Required when requiresServer is true; omitted when false.",
          "enum": ["token-mint-only", "sync-relay", "app-backend"]
        },
        "developmentSecrets": {
          "description": "Prototype-only secrets that live in gitignored local configuration — never in git, never in key slots. Each entry names the slot and why it exists. Shipping requires replacing these with a token-minting server.",
          "type": "array",
          "minItems": 1,
          "maxItems": 8,
          "uniqueItems": true,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["slot", "purpose"],
            "properties": {
              "slot": { "$ref": "#/$defs/contractId" },
              "purpose": { "$ref": "#/$defs/nonEmptyString" }
            }
          }
        },
        "ejectionRequired": { "const": true },
        "approvalRequiredFor": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "uniqueItems": true,
          "items": {
            "enum": [
              "paid-infrastructure",
              "dns-change",
              "store-submission",
              "production-credential-rotation"
            ]
          }
        },
        "operatorNotes": {
          "$ref": "#/$defs/nonEmptyStringArray"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "requiresServer": { "const": true } },
            "required": ["requiresServer"]
          },
          "then": { "required": ["serverRole"] },
          "else": { "not": { "required": ["serverRole"] } }
        }
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "required": ["operations"],
        "properties": {
          "operations": {
            "required": ["serverRole"],
            "properties": { "serverRole": { "const": "app-backend" } }
          }
        }
      },
      "then": {
        "properties": {
          "runtime": {
            "properties": {
              "privacy": {
                "properties": {
                  "externalDisclosure": { "minItems": 1 }
                }
              }
            }
          }
        }
      }
    }
  ]
}
