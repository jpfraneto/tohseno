{
  "name": "tohseno",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun --watch apps/site/server.ts",
    "start": "bun apps/site/server.ts",
    "site:icons": "bun apps/site/scripts/extract-shot-icons.ts",
    "tohseno": "bun packages/cli/src/bin.ts",
    "tohseno:link": "bun link --cwd packages/cli",
    "tohseno:release": "bun packages/cli/scripts/package-release.ts",
    "test": "bun test",
    "validate": "bun packages/manifest/cli.ts",
    "typecheck": "bunx tsc --noEmit",
    "check": "bun scripts/check.ts"
  },
  "devDependencies": {
    "@types/bun": "^1.2.18",
    "typescript": "^5.8.3"
  },
  "engines": {
    "bun": ">=1.2.18"
  }
}
